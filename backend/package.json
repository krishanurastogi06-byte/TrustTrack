{
  "name": "backend",
  "version": "1.0.0",
  "description": "TrustTrack backend API",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node ./src/server.js",
    "dev": "nodemon --watch src --exec node ./src/server.js",
    "test": "jest --forceExit --testTimeout=10000",
    "test:watch": "jest --watch",
    "lint": "echo \"Add linter scripts\"",
    "hh:compile": "hardhat compile",
    "hh:node": "hardhat node",
    "hh:deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "hh:deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.15.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ipfs-http-client": "^60.0.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.9.0",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.28.6",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  }
}
